generator client {
  provider = "prisma-client-js"
   output   = "../src/prisma/generated"
}
datasource db {
  provider = "postgresql"
}

model User{
  id         String    @id @default(uuid())
  email      String    @unique
  name       String
  push_token String?
  created_at DateTime  @default(now())
  password   String

  ledger     Point_ledger[]
  redemption Redemption[]
}

model Point_ledger{
  id          String   @id @default(uuid())
  user_id     String
  delta       Int
  reason      String
  created_at  DateTime  @default(now())

  user User @relation(fields:[user_id], references: [id])

}

model Reward{
   id                String @id @default(uuid())
   name              String 
   description       String 
   image_url         String?
   points_cost       Int
   stock_remaining   Int
   is_active         Boolean @default(true)

   redemption       Redemption[]


}

model Redemption {
   id                String   @id @default(uuid())
   user_id           String
   reward_id         String
   points_cost       Int
   created_at        DateTime  @default(now())
   idempotency_key   String    @unique



   user User @relation(fields: [user_id], references: [id])
   reward Reward @relation(fields: [reward_id], references:[id])
}